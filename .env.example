# ── AI Welding Assistant — Environment Variables ─────────────────────────────
# For LOCAL development only.
# On Hugging Face Spaces, set these in:
#   Space → Settings → Repository Secrets
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to Git.

# ── Required ──────────────────────────────────────────────────────────────────
# Your Hugging Face access token (read or write permission).
# Generate one at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# ── Optional: Model overrides ─────────────────────────────────────────────────
# Embedding model served by the HF Feature-Extraction API
# Options:
#   BAAI/bge-small-en-v1.5        (fastest, lowest memory — default)
#   BAAI/bge-base-en-v1.5         (better quality, slightly slower)
#   sentence-transformers/all-MiniLM-L6-v2
HF_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# LLM served by the HF Chat-Completion API
# Options:
#   Qwen/Qwen2.5-72B-Instruct     (best quality — default)
#   meta-llama/Llama-3.1-8B-Instruct
#   mistralai/Mistral-7B-Instruct-v0.3
HF_LLM_MODEL=Qwen/Qwen2.5-72B-Instruct

# ── Optional: Pipeline settings ───────────────────────────────────────────────
DATA_DIR=data
FAISS_INDEX_PATH=vectorstore/index.faiss
FAISS_META_PATH=vectorstore/metadata.pkl
CHUNK_SIZE=500
CHUNK_OVERLAP=100
TOP_K=5
EMBED_BATCH_SIZE=32
